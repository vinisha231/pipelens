{
  "name": "pipelens",
  "version": "0.1.0",
  "description": "AI-powered Dockerfile and CI/CD pipeline security auditor",
  "keywords": [
    "dockerfile",
    "security",
    "ci-cd",
    "github-actions",
    "gitlab-ci",
    "audit",
    "devops",
    "ai"
  ],
  "author": "Vinisha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinisha231/pipelens.git"
  },
  "homepage": "https://github.com/vinisha231/pipelens#readme",
  "bugs": {
    "url": "https://github.com/vinisha231/pipelens/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pipelens": "./dist/cli/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
