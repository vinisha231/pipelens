*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# pipelens output files (users can generate these)
pipelens-report.json
pipelens-report.html
pipelens-last-audit.json

# Temporary files
*.tmp
*.temp
